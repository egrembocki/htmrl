[flake8]
ignore = W291, E501, C901, W503, E203, E266, E402, E722, F401, F403, F821
max-line-length = 300

exclude =
    .github,
    .pytest_cache,
    .venv,
    .vscode,
    archive,
    data,
    docs,
    scripts,
    ./uv.lock,
    ./setup.py,
    ./pytest.txt,
    ./README.md,
    build,
    __pycache__,
    



    
