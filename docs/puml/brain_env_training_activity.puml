@startuml brain_env_training_activity
skinparam style strictuml
skinparam shadowing false

title Activity Detail: Agent + Trainer -> Brain -> Environment Adapter Loop

start

partition Developer {
  :Create Brain and Trainer instances;
  :Load dataset via InputHandler;
}

partition "Trainer" {
  :build_brain(fields);
  :train_full_brain(brain, dataset, steps);
}

partition "Brain" {
  :Initialize field states;
}

while (Episode active?) is (yes)
  partition "Agent" {
    :Read current state from Brain;
    :select_action(state);
  }

  partition "Env Adapter Role" {
    :Translate action for Environment;
  }

  partition "Environment" {
    :step(action);
    :observe() -> reward, next_state, done;
  }

  partition "Agent" {
    :update(state, action, reward, next_state);
  }

  partition "Brain" {
    :encode_only(inputs);
    :compute_only(learn=True);
    :prediction();
  }

  if (done?) then (yes)
    partition "Environment" {
      :reset();
    }
  else (no)
  endif
endwhile (no)

partition Trainer {
  :print_train_stats();
}

partition Developer {
  :Review metrics and retrain if needed;
}

stop
@enduml
