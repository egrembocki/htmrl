@startuml
skinparam style strictuml
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true

title US-07 Use HTM Engine: ColumnField.compute()

actor "Brain" as B
participant "<u>cf:ColumnField</u>" as CF
participant "Cell/Segment/Synapse State" as H

B -> CF: compute(learn=True|False)
activate CF
CF -> H: advance states (active/predictive/winner)
CF -> H: compute overlap from encoded input bits
CF -> H: activate columns and cells
CF -> H: depolarize / set predictive cells

alt learn=True
  CF -> H: reinforce active segments/synapses
  CF -> H: punish predicted-but-inactive segments
  CF -> H: update duty cycles / boost stats
end

CF --> B: updated field state\n(active_cells, predictive_cells, bursting_columns, metrics)
deactivate CF
@enduml
