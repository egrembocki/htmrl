@startuml
skinparam style strictuml
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
title US-10 End-to-End Data to HTM Summary (Current Code)

actor Developer
participant "InputHandler" as IH
participant "EncoderHandler" as EH
participant "FourierEncoder" as FFT
participant "Brain" as BR
participant "ColumnField" as CF

Developer -> IH: input_data(input_source, required_columns?)
activate IH
IH -> IH: _is_file_path(input_source)
alt supported file path
  IH -> IH: _load_file_to_dataframe(path)
else in-memory payload
  IH -> IH: _coerce_non_file_to_dataframe(input_source)
end
IH -> IH: _process_dataframe(df, required_columns)
IH --> Developer: records: list[dict[Any, Any]]
deactivate IH

alt record/categorical pipeline
  Developer -> EH: build_composite_sdr(records)
  activate EH
  loop for each row and column
    EH -> EH: select encoder by value type
    EH -> EH: encode(value) + concatenate row SDR
  end
  EH --> Developer: row_sdrs: list[SDR]
  deactivate EH
else frequency pipeline
  Developer -> IH: to_encoder_sequence(input_source, required_columns?, column?)
  activate IH
  IH -> IH: input_data(...)
  IH -> IH: infer/sanitize sequence column
  IH --> Developer: sequence list[Any]
  deactivate IH

  Developer -> FFT: encode(np.ndarray(sequence))
  activate FFT
  FFT -> FFT: _trim + scipy.fft.fft + range encoding
  FFT --> Developer: frequency SDR
  deactivate FFT
end

Developer -> BR: step(inputs, learn=True)
activate BR
BR -> BR: encode_only(inputs)
BR -> CF: compute(learn=True)
activate CF
CF --> BR: updated HTM state
deactivate CF
BR --> Developer: decoded output map
deactivate BR
@enduml
