@startuml
skinparam style strictuml
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true

title US-08 Test Model: Trainer.test()

actor Developer
participant "<u>tr:Trainer</u>" as TR
participant "<u>b:Brain</u>" as BR
participant "<u>cf:ColumnField</u>" as CF

Developer -> TR: test(brain, dataset, steps?)
activate TR
TR -> TR: validate dataset and compute effective steps

loop each evaluation step
  TR -> BR: prediction()
  BR --> TR: predictions dict
  TR -> TR: compare expected vs predicted\n(update mse + failures)

  TR -> BR: step(inputs_t, learn=False)
  BR -> CF: compute(learn=False)
  CF --> BR: updated inference state
  BR --> TR: behavior output

  TR -> TR: collect bursting column counts
end

TR -> TR: aggregate global MSE + per-field metrics
TR --> Developer: metrics dict + formatted summary
deactivate TR
@enduml
