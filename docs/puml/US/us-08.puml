@startuml
scale 2000 width
scale 2000 height
skinparam TitleFontSize 40
skinparam ObjectFontSize 30
skinparam DefaultFontSize 32
skinparam style strictuml
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true

title US-08 Test Model (TODO: Update to match planned Brain HTM+RL evaluation flow)

actor Developer
participant "<u>trainer:Trainer</u>" as TM
participant "<u>b:Brain</u>" as BR
participant "<u>cf:ColumnField</u>" as CF
participant "<u>rla:RL Adapter\n(planned)</u>" as RLA
participant "<u>rlm:RL Model\n(Policy/Value)</u>" as RLM
participant "<u>env:Environment</u>" as ENV
participant "<u>mc:Metrics/Checkpoint\n(planned)</u>" as MC

group US-08A Current Code Reality
  Developer -> BR: step(inputs, learn=False)
  activate BR
  BR -> BR: encode_only(inputs)
  BR -> CF: compute(learn=False)
  CF --> BR: inference state
  BR --> Developer: decoded outputs / predictions
  deactivate BR

  note over BR
  No dedicated test_model API or RL evaluation
  framework is currently implemented.
  end note
end

group US-08B Planned RL Model Testing Loop (Figure 6-1 / 6-2 Alignment)
  Developer -> TM: evaluate_with_rl(test_config, episodes)
  activate TM

  loop each evaluation episode
    TM -> BR: reset episode context
    activate BR
    BR --> TM: initial state ready
    deactivate BR

    loop each timestep
      TM -> BR: step(observation_t, learn=False)
      activate BR
      BR -> RLA: export state/action context
      activate RLA
      RLA -> RLM: infer_action(state_t)
      activate RLM
      RLM --> RLA: action_t (+ score/logits)
      deactivate RLM
      RLA --> BR: action_t
      deactivate RLA

      BR -> ENV: apply(action_t)
      activate ENV
      ENV --> BR: reward_t, next_state_t, done
      deactivate ENV

      BR --> TM: prediction_t, reward_t, done
      deactivate BR

      TM -> MC: log evaluation metrics
      activate MC
      MC --> TM: aggregated stats updated
      deactivate MC

      alt done == true
        break
      end
    end

    TM -> MC: write episode test report
    activate MC
    MC --> TM: report artifact/path
    deactivate MC
  end

  TM --> Developer: RL evaluation summary
  deactivate TM
end

note over BR,RLM
Planned test flow keeps Brain as the interface boundary
between HTM state and RL policy/value evaluation.
end note
@enduml
