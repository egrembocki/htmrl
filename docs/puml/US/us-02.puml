@startuml
skinparam style strictuml
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
title US-02 Validate Data (Current InputHandler._validate_data)

actor Developer
participant "InputHandler" as IH
participant "Logger" as LOG

Developer -> IH: _validate_data(required_columns?)
activate IH
IH -> IH: resolve columns from self._columns or first record
IH -> IH: detect all-None columns (excluding appended placeholders)
IH -> IH: find missing required columns

alt self._data is empty
  IH -> LOG: info("Record list is empty")
  IH --> Developer: ("Record list is empty", False)
else self._data is not list[Mapping]
  IH -> LOG: info("Data is not a list of records")
  IH --> Developer: ("Data is not a list of records.", False)
else duplicate column names detected
  IH -> LOG: info("Duplicate column names detected")
  IH --> Developer: ("Record list has duplicate column names.", False)
else non-required columns are all None
  IH -> LOG: info("Columns with all None values detected")
  IH --> Developer: ("Columns with all None values: ...", False)
else appended required placeholders exist
  IH -> LOG: info("Appended required columns with placeholder values")
  IH --> Developer: ("Appended required columns with placeholder values.", False)
else required columns are missing
  IH -> LOG: info("Missing required columns")
  IH --> Developer: ("Missing required columns: ...", False)
else valid dataset
  IH -> LOG: info("data has been validated")
  IH --> Developer: ("Data is valid.", True)
end

deactivate IH
@enduml
