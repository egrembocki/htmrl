@startuml
skinparam style strictuml
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true

title US-02 Validate Data: InputHandler._process_dataframe()

participant Caller
participant "<u>ih:InputHandler</u>" as IH
participant "Logger" as LOG

Caller -> IH: _process_dataframe(df, required_columns?)
activate IH

alt df.empty
  IH -> IH: self._repeating_columns = []
  IH -> IH: self._is_repeating = false
  IH --> Caller: empty DataFrame
else non-empty dataframe
  opt duplicate column names
    IH -> LOG: info("Duplicate columns detected")
    IH -> IH: df = df.loc[:, ~df.columns.duplicated()]
  end

  opt required_columns provided
    IH -> IH: add missing required columns as None
    IH -> IH: df = df[required_columns]
  end

  IH -> IH: _normalize_datetime_columns(df)
  IH -> IH: _normalize_column_types(df)
  IH -> IH: _fill_missing_values(df)
  IH -> IH: _detect_repeating_values(df, threshold=3)
  IH --> Caller: processed DataFrame
end

deactivate IH
@enduml
