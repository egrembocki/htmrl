@startuml
skinparam style strictuml
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true

title US-10 Decode SDR to Value: Brain.prediction()

actor Developer as Dev
participant "<u>b:Brain</u>" as BR
participant "<u>if:InputField</u>" as IF
participant "<u>enc:Encoder</u>" as ENC
participant "<u>of:OutputField</u>" as OF

Dev -> BR: prediction()
activate BR

loop each input field
  BR -> IF: decode("predictive")
  IF -> ENC: decode(bit_vector, candidates?)
  ENC --> IF: value, confidence
  IF --> BR: value + confidence
end

loop each output field
  BR -> OF: decode()
  OF --> BR: {value, confidence}
end

BR --> Dev: predictions dict\n(input + input.conf + action_*.conf keys)
deactivate BR
@enduml
