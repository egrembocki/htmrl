@startuml
skinparam style strictuml
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
title US-01 Input Data: InputHandler.input_data()

actor Developer
participant "<u>ih:InputHandler</u>" as IH
participant "Filesystem\n<pathlib.Path>" as FS
participant "Pandas IO" as PD

Developer -> IH: input_data(input_source, required_columns?)
activate IH
IH -> IH: _is_file_path(input_source)

alt input_source is supported file path
  IH -> FS: exists() and is_file()
  activate FS
  FS --> IH: true/false
  deactivate FS

  alt file exists
    IH -> PD: read_csv/read_json/read_excel/read_parquet/read_text
    activate PD
    PD --> IH: df
    deactivate PD
  else file does not exist
    IH --> Developer: raise FileNotFoundError
    deactivate IH
  end
else in-memory payload
  IH -> IH: _coerce_non_file_to_dataframe(input_source)
  IH --> IH: df
end

IH -> IH: _process_dataframe(df, required_columns)
IH -> IH: _normalize_datetime_columns(df)
IH -> IH: _normalize_column_types(df)
IH -> IH: _fill_missing_values(df)
IH -> IH: _detect_repeating_values(df, threshold=3)
IH -> IH: self._columns = list(df.columns)
IH -> IH: self._data = df.to_dict(orient="records")
IH --> Developer: list[dict[Any, Any]]
deactivate IH
@enduml
