@startuml
skinparam style strictuml
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true

title US-01 Input Data: InputHandler.input_data()

actor Developer
participant "<u>ih:InputHandler</u>" as IH
participant "Filesystem\n<pathlib.Path>" as FS
participant "Pandas IO" as PD

Developer -> IH: input_data(input_source, required_columns?)
activate IH
IH -> IH: _is_file_path(input_source)

alt path-like + supported extension
  IH -> IH: _load_file_to_dataframe(path)
  IH -> FS: exists() and is_file()
  FS --> IH: true/false

  alt file exists
    IH -> PD: read_csv/read_json/read_excel/read_parquet/read_text
    PD --> IH: DataFrame
  else file missing
    IH --> Developer: FileNotFoundError
    deactivate IH
  end
else in-memory payload
  IH -> IH: _coerce_non_file_to_dataframe(input_source)
  IH --> IH: DataFrame
end

IH -> IH: _process_dataframe(df, required_columns)
IH -> IH: self._columns = list(df.columns)
IH -> IH: self._data = df.to_dict(orient="list")
IH --> Developer: dict[Any, list[Any]]
deactivate IH
@enduml
