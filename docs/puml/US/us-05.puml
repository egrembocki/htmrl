@startuml
skinparam style strictuml
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
title US-05 Train Model:Brain/InputField/ColumnField learning loop

actor Developer
participant "Brain" as B
participant "InputField" as IFTS
participant "InputField" as IFKWH
participant "ColumnField" as CF
participant "HTM Engine\n(inside ColumnField.compute)" as H

== Build brain runtime ==
Developer -> B: build_brain(field_sizes)
activate B
B -> IFTS: create InputField(BaseEncoder)
B -> IFKWH: create InputField(BaseEncoder)
B -> CF: create ColumnField(input_fields)
CF -> H: initialize columns/cells/segments
H --> CF: ready
B --> Developer: brain instance

deactivate B

== Training loop (learn=True) ==
loop each normalized row
  Developer -> B: step(row, learn=True)
  activate B

  group Brain.encode_only(inputs)
    B -> IFKWH: encode(value)
    activate IFKWH
    IFKWH -> IFKWH: advance_states()
    IFKWH -> IFKWH: encoder.encode(value)
    IFKWH --> B: encoded bits + active cells
    deactivate IFKWH

    B -> IFTS: encode(value)
    activate IFTS
    IFTS -> IFTS: advance_states()
    IFTS -> IFTS: encoder.encode(value)
    IFTS --> B: encoded bits + active cells
    deactivate IFTS
  end

  group Brain.compute_only(learn=True)
    B -> CF: compute(learn=True)
    activate CF
    CF -> H: advance_states()
    H -> H: compute_overlap() + activate_columns()
    H -> H: activate_cells() + depolarize_cells()

    loop learning updates when learn=True
      H -> H: learn_columns()
      H -> H: learn()\n(grow/adapt/weaken segments)
    end

    H -> H: set_prediction() + update duty cycles
    CF --> B: column/cell states updated
    deactivate CF
  end

  B --> Developer: prediction()
  deactivate B
end
@enduml
