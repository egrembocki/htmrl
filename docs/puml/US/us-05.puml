@startuml
scale 2000 width
scale 2000 height
skinparam style strictuml
skinparam defaultFontSize 32
skinparam TitleFontSize 40
skinparam ObjectFontSize 30

skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true

title US-05 Train Model: Trainer

actor Developer as Dev
participant "<u>t:Trainer</u>" as TR
participant "<u>b:Brain</u>" as BR
participant "Dataset" as DS

Dev -> TR: Trainer(Brain({}))
activate TR
TR -> BR: initialize Brain
BR --> TR: brain ready

alt Explicit field-control build
  Dev -> TR: build_brain(fields, possible_actions?)
  TR -> BR: create fields from tuples
  BR --> TR: brain built
else Dataset-driven quick build
  Dev -> TR: build_full_brain(dataset, size, params)
  TR -> BR: infer fields from dataset
  BR --> TR: brain built
else Environment-driven build
  Dev -> TR: build_brain_for_env(adapter, config)
  TR -> BR: map env observation/action spec
  BR --> TR: brain built
end

TR --> Dev: configured Brain

Dev -> TR: train_full_brain(brain, dataset, steps)
TR -> DS: iterate training samples

loop training steps
  TR -> BR: step(sample, learn=True)
  BR -> BR: encode -> spatial pool -> temporal learn
  BR --> TR: active columns / predictions
end

Dev -> TR: test(brain, dataset, steps)
TR --> Dev: metrics {accuracy, confidence, training stats}
deactivate TR
@enduml
