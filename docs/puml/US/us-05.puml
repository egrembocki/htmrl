@startuml
skinparam style strictuml
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
title US-05 Train Model (Orchestrates training, delegates to Brain)

actor Developer as D
participant "TrainModel" as TM
participant "Brain" as B

D -> TM: start_training(dataset, epochs)
activate TM

loop each training row
  TM -> B: step(row, learn=True)
  activate B
  note right of B
    Brain owns encoding + HTM calls.
    TrainModel does not call HTM directly.
  end note

  B --> TM: prediction,confidence,debug_stats
  
  deactivate B
end

TM --> D: training summary / metrics

deactivate TM
@enduml
