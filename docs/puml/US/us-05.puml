@startuml
skinparam style strictuml
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
title US-05 Train Model: Brain delegates to HTM

actor Developer
participant "Brain" as B
participant "HTM" as H
participant "InputField" as IFTS
participant "InputField" as IFKWH
participant "ColumnField" as CF

group Build brain runtime
  Developer -> B: build_brain(field_sizes)
  activate B
  B -> H: initialize InputFields + ColumnField
  H --> B: ready
  B --> Developer: brain instance
  deactivate B
end

group Training loop (learn=True)
  loop each normalized row
    Developer -> B: step(row, learn=True)
    activate B
    B -> H: step(inputs, learn)
    activate H

    H -> IFKWH: encode(kw_energy_consumption)
    IFKWH --> H: encoded bits

    H -> IFTS: encode(timestamp)
    IFTS --> H: encoded bits

    H -> CF: compute(learn=True)
    CF --> H: updated active/predictive state

    H --> B: prediction()
    deactivate H
    B --> Developer: prediction()
    deactivate B
  end
end
@enduml
