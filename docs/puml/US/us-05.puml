@startuml
scale 2000 width
scale 2000 height
skinparam style strictuml
skinparam defaultFontSize 32
skinparam TitleFontSize 40
skinparam ObjectFontSize 30

skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true

title US-05 Train Model: train_cartpole_brain_policy()

actor Developer as Dev
participant "<u>entry:train_cartpole_brain_policy</u>" as Entry
participant "<u>builder:build_cartpole_brain</u>" as Build
participant "<u>adapter:EnvAdapter</u>" as EA
participant "<u>a:Agent</u>" as AG
participant "<u>b:Brain</u>" as BR
participant "Gym Env" as ENV

Dev -> Entry: train_cartpole_brain_policy(config?)
activate Entry
Entry -> EA: EnvAdapter("CartPole-v1")
Entry -> Build: build_cartpole_brain(adapter, config)
Build --> Entry: brain
Entry -> AG: Agent(brain, adapter, policy_mode="brain")

loop episodes
  Entry -> AG: reset_episode()
  loop while not done and steps < max_steps_per_episode
    Entry -> AG: step(learn=True)
    activate AG
    AG -> BR: step(inputs + reward, learn=True)
    BR --> AG: brain_outputs
    AG -> AG: select_action(obs, brain_outputs)
    AG -> EA: step_bridge(action)
    EA -> ENV: step(action)
    ENV --> EA: obs, reward, terminated, truncated, info
    EA --> AG: transition bridge
    AG -> AG: update(obs, action, reward, next_obs, done)
    AG --> Entry: transition
    deactivate AG
  end
  Entry -> BR: print_stats()
end

Entry --> Dev: metrics {episode_rewards, steps, mean_reward, best_reward}
deactivate Entry
@enduml
