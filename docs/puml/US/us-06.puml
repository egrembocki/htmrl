@startuml us-06-train-brain
skinparam style strictuml
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true

title US-06 Train Brain (Trainer, Brain)

actor Developer as D
participant "trainer:Trainer" as TM
participant "brain:Brain" as B

D -> TM: train_brain(config, data)
activate TM
TM -> B: fit(data)
activate B
B -> TM: feedback, stats
TM -> B: step(inputs, learn=True)
B --> TM: prediction, model update
deactivate B
TM --> D: training report + model refs
deactivate TM
@enduml
