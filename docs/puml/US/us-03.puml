@startuml
skinparam style strictuml
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true

title US-03 Encode Data: Brain.step(inputs, learn)

actor Developer
participant "<u>b:Brain</u>" as B
participant "<u>if:InputField</u>" as IF
participant "<u>cf:ColumnField</u>" as CF
participant "<u>of:OutputField</u>" as OF

Developer -> B: step(inputs, learn=True)
activate B
B -> B: encode_only(inputs)
loop each registered input present in inputs
  B -> IF: encode(value)
  IF --> B: encoded SDR on input field
end

B -> B: compute_only(learn=True)
loop each column/value field
  B -> CF: compute(learn=True)
  CF --> B: updated HTM state
end

B -> B: estimate_value(reward?)
B -> B: activate_apical_segments()
B -> B: generate_behavior()
loop each output field
  B -> OF: compute()
  OF --> B: decode() -> {value, confidence}
end

B --> Developer: behavior map {output_name: {action, confidence}}
deactivate B
@enduml
