@startuml
skinparam style strictuml
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
title US-03 Encode Data (Brain delegates encoding to HTM)

actor Developer
participant "InputHandler" as IH
participant "Brain" as B
participant "HTM" as H
participant "InputField" as IFTS
participant "InputField" as IFKWH
participant "ColumnField" as CF

group Input layer produces reusable output
  Developer -> IH: input_data(data, required_columns)
  activate IH
  IH -> IH: validate data
  IH --> Developer: input_data(): dict[key:, list[value]]

  deactivate IH
  Developer -> B: step(input_data, learn=True)
end

group Brain delegates encoding/computation to HTM
  loop each normalized row
    Developer -> B: step(normalize_for_brain(row), learn=True)
    activate B
    B -> H: step(inputs, learn)
    activate H

    H -> IFKWH: encode(value:Any)
    activate IFKWH
    IFKWH -> IFKWH: Encoder encode -> active bits
    IFKWH --> H: encoded bits
    deactivate IFKWH

    H -> IFTS: encode(value:Any)
    activate IFTS
    IFTS -> IFTS: Encoder encode -> active bits
    IFTS --> H: encoded bits
    deactivate IFTS

    H -> CF: compute(learn)
    activate CF
    CF --> H: updated active/predictive state
    deactivate CF

    H --> B: prediction()
    deactivate H
    B --> Developer: prediction()
    deactivate B
  end
end
@enduml
