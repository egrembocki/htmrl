@startuml
skinparam style strictuml
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true

title US-03 Encode Data

actor Developer
participant "<u>ih:InputHandler</u>" as IH
participant "<u>b:Brain</u>" as B
participant "<u>if:InputField</u>" as IF
participant "<u>be:BaseEncoder\n(concrete implementation)</u>" as BE
participant "<u>h:ColumnField</u>" as H

group Input layer prepares normalized rows
  Developer -> IH: input_data(data, required_columns)
  activate IH
  IH -> IH: validate + normalize
  IH --> Developer: normalized rows
  deactivate IH
end

group Brain orchestrates encoding and compute
  loop each normalized row
    Developer -> B: step(row_inputs, learn=True)
    activate B

    B -> IF: encode(value)
    activate IF
    IF -> BE: encode(value)
    activate BE
    BE --> IF: encoded_bits
    deactivate BE
    IF -> IF: set active cells from encoded_bits
    IF --> B: encoded_bits
    deactivate IF

    B -> H: compute(learn=True)
    activate H
    H --> B: active/predictive state
    deactivate H

    B --> Developer: step result
    deactivate B
  end
end

note over IF,BE
InputField performs the delegation call.
The concrete BaseEncoder implementation executes encode(value).
end note
@enduml
