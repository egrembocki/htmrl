@startuml
skinparam style strictuml
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
title US-03 Encode Data (Brain delegates encoding to HTM)

actor TrainModel
participant "InputHandler" as IH
participant "InputLayer Output\n(normalized records)" as ILO
participant "Brain" as B
participant "HTM" as H
participant "InputField\n(timestamp)" as IFTS
participant "InputField\n(kw_energy_consumption)" as IFKWH
participant "ColumnField" as CF

group Input layer produces reusable output
  TrainModel -> IH: input_data(file, required_columns)
  activate IH
  IH -> IH: validate + normalize source data
  IH --> TrainModel: to_records(limit)
  deactivate IH
  TrainModel -> ILO: store normalized record list
end

group Brain delegates encoding/computation to HTM
  loop each normalized row
    TrainModel -> B: step(normalize_for_brain(row), learn=True)
    activate B
    B -> H: step(inputs, learn)
    activate H

    H -> IFKWH: encode(kw_energy_consumption)
    activate IFKWH
    IFKWH -> IFKWH: RDSE encode -> active cells
    IFKWH --> H: encoded bits
    deactivate IFKWH

    H -> IFTS: encode(timestamp)
    activate IFTS
    IFTS -> IFTS: RDSE encode -> active cells
    IFTS --> H: encoded bits
    deactivate IFTS

    H -> CF: compute(learn)
    activate CF
    CF --> H: updated active/predictive state
    deactivate CF

    H --> B: prediction()
    deactivate H
    B --> TrainModel: prediction()
    deactivate B
  end
end
@enduml
