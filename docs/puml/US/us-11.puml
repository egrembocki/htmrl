@startuml
skinparam style strictuml
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
autonumber

title US-11 Decode SDR to Value (Current Code Support)

actor TrainModel
participant "Brain" as BR
participant "InputField" as IF
participant "RDSE / Scalar / Date / Category / Fourier Encoder" as ENC

TrainModel -> BR: prediction()
activate BR
loop for each registered input field
  BR -> IF: decode("predictive")
  activate IF
  IF -> IF: build bit_vector from cell.predictive
  IF -> ENC: decode(bit_vector, candidates?)
  activate ENC
  ENC --> IF: decoded value + confidence
  deactivate ENC
  IF --> BR: tuple(value, confidence)
  deactivate IF
end
BR --> TrainModel: dict[input_name, value/confidence]
deactivate BR

alt direct decoder usage in tests/scripts
  TrainModel -> ENC: encode(input)
  ENC --> TrainModel: encoded SDR bits
  TrainModel -> ENC: decode(encoded, candidates?)
  ENC --> TrainModel: value/confidence or decoded dict
end

note over ENC
Decoding support is implemented across encoder classes.
Round-trip decode behavior is validated in decoder test suites.
end note
@enduml
