@startuml
skinparam style strictuml
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
autonumber

title US-11 Decode SDR to Value (Prediction Originates in Brain/HTM)

actor "Developer" as Dev
participant "Brain" as BR
participant "HTM / ColumnField" as HTM
participant "InputField" as IF
participant "RDSE / Scalar / Date / Category / Fourier Encoder" as ENC

Dev -> BR: step(inputs, learn=False)
activate BR
BR -> HTM: compute(learn=False)
activate HTM
HTM --> BR: predictive state
deactivate HTM

BR -> BR: prediction() uses predictive state
loop for each registered input field
  BR -> IF: decode("predictive")
  activate IF
  IF -> IF: build bit_vector from cell.predictive
  IF -> ENC: decode(bit_vector, candidates?)
  activate ENC
  ENC --> IF: decoded value + confidence
  deactivate ENC
  IF --> BR: tuple(value, confidence)
  deactivate IF
end
BR --> Dev: dict[input_name, value/confidence]
deactivate BR

alt direct decoder usage in tests/scripts
  Dev -> ENC: encode(input)
  ENC --> Dev: encoded SDR bits
  Dev -> ENC: decode(encoded, candidates?)
  ENC --> Dev: value/confidence or decoded dict
end

note over BR,HTM
Predictions are produced from Brain/HTM predictive state,
then decoded by InputField + encoder decode APIs.
end note
@enduml
