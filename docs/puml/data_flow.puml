@startuml data_flow
title Data Flow Through PSU Capstone System

participant "Data Source" as source
participant "InputHandler\n(Input Layer)" as input
participant "EncoderHandler\n(Encoder Layer)" as encoder
participant "SDR\n(SDR Layer)" as sdr
participant "Agent/Brain\n(Agent Layer)" as agent
participant "Environment" as env
participant "Visualization\n(grapher.py)" as viz

source ->> input: raw data (CSV, JSON, file)
activate input
input ->> input: validate_data()
input ->> input: normalize_data()
input -->> source: confirmation

input ->> encoder: to_encoder_sequence()
deactivate input

activate encoder
encoder ->> encoder: get appropriate encoder\n(scalar, category, date, etc.)
encoder ->> encoder: encode(value) -> SDR bits
encoder -->> sdr: encoded SDR
deactivate encoder

activate sdr
sdr ->> sdr: store active bits\ncompute density & nBits
sdr -->> agent: SDR representation
deactivate sdr

activate agent
agent ->> agent: spatial_pooler.compute(SDR)
agent ->> agent: temporal_memory.compute()
agent ->> agent: learn() or predict()
agent -->> agent: predictions/anomalies
deactivate agent

agent ->> env: send to environment\nfor evaluation
activate env
env ->> env: compute reward/feedback
env -->> agent: feedback signal
deactivate env

agent ->> viz: predictions + metrics\n+ visualizations
activate viz
viz ->> viz: generate plots\nstore results
viz -->> source: END (visualization output)
deactivate viz

@enduml
