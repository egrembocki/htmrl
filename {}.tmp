    """Test that scalar encoder rounds to the nearest multiple of resolution correctly."""

    # Arrange
    params = ScalarEncoderParameters(
        minimum=10,
        maximum=20,
        clip_input=False,
        periodic=False,
        active_bits=3,
        sparsity=0.0,
