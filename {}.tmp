    df = pd.DataFrame(
        [
            {
                "float_col": float(3.14),  # rdse
                "int_col": int(42),  # scalar
                "str_col": str("B"),  # category
                "date_col": datetime(2023, 12, 25),  # date
            }
        ]
    )

    handler = EncoderHandler(df)

    return handler


def test_handler_singleton(handler: EncoderHandler):
